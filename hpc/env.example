# Example environment variables for the MareNostrum 5 ACC deployment.
# Copy this file to `hpc/env.local` (gitignored) and source it on the login
# node before submitting jobs:
#
#   source hpc/env.local
#   sbatch hpc/slurm/lipsync_single.sbatch
#
# MN5 ACC notes: discover your project allocation with
#   sacctmgr show user $USER format=user,account,qos,partition
# Replace the placeholders below with the values it prints for your project.

# === SLURM project allocation ===
export MUSETALK_ACCOUNT="bsc99"          # SLURM --account (replace)
export MUSETALK_QOS="acc_bsccs"          # SLURM --qos     (replace)

# === Cluster paths (defaults match BSC MN5) ===
# $PROJECT is the project-wide persistent storage (GPFS), shared between
# login and compute nodes. $SCRATCH is the per-user fast scratch.
# Both are auto-set by the MN5 environment; we only document them here.

# === Image + cache paths ===
export IMAGE="$PROJECT/musetalk/musetalk-v8-hpc.sif"
export CACHE_DIR="$PROJECT/musetalk_cache"
export OUTPUT_DIR="$PROJECT/musetalk_outputs"

# === Defaults for sbatch --export ===
# Override these per-job when needed via the sbatch --export=... line.
export CLIPS_DIR="$PROJECT/inputs/michele_monaco"
export AUDIO="$PROJECT/inputs/audio.wav"

export SEED="42"
export EXTRA_MARGIN="15"                 # works well for michele_monaco set
export LEFT_CHEEK_WIDTH="110"
export RIGHT_CHEEK_WIDTH="110"
export PARSING_MODE="jaw"
export BATCH_SIZE="16"
export USE_NVENC="1"                     # H100 has no NVENC but the engine
                                         # falls back to libx264 transparently
export QUALITY="0"                       # 1 → enable GFPGAN preset
